# rosbot environment configuration
# Copy to .env and fill in your values:
#   cp .env.example .env
# .env is gitignored — never commit API keys or GPU UUIDs

# ── LLM backend ──────────────────────────────────────────────────────────────
# vLLM (local) is used when LLM_BASE_URL is set; falls back to Anthropic
LLM_BASE_URL=http://localhost:8001/v1
LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct
# ANTHROPIC_API_KEY=sk-ant-...

# ── ROS2 connection ───────────────────────────────────────────────────────────
# Use ws://sim:9090 inside Docker Compose, ws://localhost:9090 for local ROS
ROSBRIDGE_URL=ws://sim:9090
# Set true for TurtleBot4 (uses TwistStamped); false for standard Twist robots
TWIST_STAMPED=true

# ── Web server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8082

# ── Simulation ────────────────────────────────────────────────────────────────
SIM_MODE=true
TURTLEBOT4_MODEL=standard
# TB4_WORLD options: depot, maze, warehouse
TB4_WORLD=depot
# Required for Gazebo/Ogre2 rendering — without a GPU, sim runs at ~0.3% real-time
# Find UUIDs with: nvidia-smi -L
# Example: SIM_GPU=GPU-57456950-e6dd-3f97-baac-42c6a9cc3431
SIM_GPU=
LIBGL_ALWAYS_INDIRECT=0

# ── Whisper voice transcription ───────────────────────────────────────────────
# Model sizes: tiny, base, small, medium (larger = more accurate, slower)
WHISPER_MODEL=base

# ── vLLM GPU settings ─────────────────────────────────────────────────────────
# Find UUIDs with: nvidia-smi -L
# Example: VLLM_GPUS=GPU-xxxxxxxx-...,GPU-yyyyyyyy-...
VLLM_GPUS=
VLLM_TP=4

# ── HuggingFace (required for gated models like Llama) ───────────────────────
# Get token at: https://huggingface.co/settings/tokens
# HUGGING_FACE_HUB_TOKEN=hf_...
