# rosbot environment configuration
# Copy to .env and edit as needed
# .env is gitignored — never commit API keys

# LLM backend — vLLM (local) takes priority over Anthropic
LLM_BASE_URL=http://localhost:8001/v1
LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct
# ANTHROPIC_API_KEY=sk-ant-...

# ROS2 connection
ROSBRIDGE_URL=ws://sim:9090
TWIST_STAMPED=false

# Whisper voice transcription: tiny, base, small, medium
WHISPER_MODEL=base

# TurtleBot4 sim
TURTLEBOT4_MODEL=standard
TB4_WORLD=warehouse
SIM_MODE=true

# Web UI port
PORT=8082
